@model AutoCarShowroom.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập quản trị";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<section class="login-shell">
    <div class="login-panel">
        <span class="section-kicker">Khu vực quản trị</span>
        <h1>Đăng nhập để quản lý showroom</h1>
        <p class="text-muted">
            Sau khi đăng nhập, bạn có thể thêm xe mới, cập nhật hình ảnh, chỉnh sửa thông tin
            và xoá mẫu xe khỏi bộ sưu tập đang trưng bày.
        </p>

        <form asp-controller="Account" asp-action="Login" method="post" class="app-form mt-4">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Nhập tài khoản quản trị" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-accent btn-lg">Đăng nhập</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark">Quay về trang chủ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
