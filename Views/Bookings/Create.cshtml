@model BookingCreateViewModel

@{
    ViewData["Title"] = "Đặt lịch xem xe";
    ViewData["ChatbotCurrentCarId"] = Model.CarId;
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Đặt lịch</span>
            <h1>Đặt lịch xem xe</h1>
        </div>
        <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.CarId" class="btn btn-outline-light">Quay lại xe</a>
    </div>

    <div class="checkout-layout">
        <div class="checkout-panel">
            <span class="section-kicker">Thông tin khách hàng</span>
            <form asp-action="Create" method="post" class="app-form mt-4">
                @Html.AntiForgeryToken()
                <input asp-for="CarId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label"></label>
                        <input asp-for="CustomerName" class="form-control" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" type="tel" inputmode="numeric" autocomplete="tel-national" maxlength="10" minlength="10" pattern="0[0-9]{9}" placeholder="09xxxxxxxx" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AppointmentAt" class="form-label"></label>
                        <input asp-for="AppointmentAt" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" />
                        <span asp-validation-for="AppointmentAt" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Note" class="form-label"></label>
                        <textarea asp-for="Note" class="form-control" rows="4" placeholder="Ví dụ: muốn xem xe vào buổi sáng, cần nhân viên gọi trước..."></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                </div>

                <div class="checkout-submit">
                    <button type="submit" class="btn btn-accent">Xác nhận đặt lịch</button>
                </div>
            </form>
        </div>

        <aside class="summary-panel">
            <span class="section-kicker">Mẫu xe đã chọn</span>
            <div class="checkout-items">
                <article class="checkout-item">
                    <img src="@Model.Car.Image" alt="@Model.Car.CarName" class="checkout-item__image" />
                    <div>
                        <p class="car-card__eyebrow">@Model.Car.Brand @Model.Car.ModelName</p>
                        <h3>@Model.Car.CarName</h3>
                        <p class="cart-item-card__price">@Model.Car.Price.ToString("N0") VNĐ</p>
                    </div>
                </article>
            </div>
            <p class="checkout-note">Quản trị viên sẽ xem lịch hẹn của bạn và chủ động liên hệ xác nhận.</p>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
