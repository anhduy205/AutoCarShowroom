@model AutoCarShowroom.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập nội bộ";
    Layout = "/Views/Shared/_Layout.cshtml";
}

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<section class="login-shell">
    <div class="login-panel">
        <span class="section-kicker">Khu vực nội bộ</span>
        <h1>Đăng nhập để quản lý showroom</h1>
        <p class="text-muted">
            Tài khoản nội bộ có thể vào kho xe, đơn mua, lịch hẹn và doanh thu tùy theo quyền đã cấu hình.
        </p>

        <form asp-controller="Account" asp-action="Login" method="post" class="app-form mt-4">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Nhập tài khoản nội bộ" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <div class="login-panel__hint">
                <strong>Tài khoản demo để test:</strong>
                <span><code>admin / Admin@123</code></span>
                <span><code>team01 / Team@123</code></span>
                <span><code>team02 / Team@123</code></span>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-accent btn-lg">Đăng nhập</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark">Quay về trang chủ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
