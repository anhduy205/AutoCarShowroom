@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoCarShowroom</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoCarShowroom.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var isBackOffice = InternalAccess.IsBackOffice(User);
        var canAccessRevenue = InternalAccess.CanAccessRevenue(User);
        var roleLabel = User.IsInRole(InternalAccess.RoleAdmin) ? "Quản trị" : "Nhân viên nội bộ";
        var showChatbot = !isBackOffice && !Context.Request.Path.StartsWithSegments("/Account/Login");
        var currentChatbotCarId = ViewData["ChatbotCurrentCarId"] is int chatCarId ? chatCarId : (int?)null;
        var chatbotRequestToken = showChatbot ? Antiforgery.GetAndStoreTokens(Context).RequestToken : null;
    }

    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="navbar-brand__mark">AC</span>
                    <span class="navbar-brand__text">
                        <span class="navbar-brand__title">AutoCarShowroom</span>
                        <span class="navbar-brand__subtitle">Showroom ô tô trực tuyến</span>
                    </span>
                </a>

                <button class="navbar-toggler navbar-dark" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Mở menu điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="Index">Xem xe</a>
                        </li>
                        @if (isBackOffice)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminOrders" asp-action="Index">Đơn mua xe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminBookings" asp-action="Index">Khách đặt lịch</a>
                            </li>
                            @if (canAccessRevenue)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminRevenue" asp-action="Index">Doanh thu</a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Giới thiệu đồ án</a>
                        </li>
                    </ul>

                    <div class="d-flex flex-wrap align-items-center gap-2">
                        @if (isBackOffice)
                        {
                            <span class="admin-chip">@roleLabel: @(User.Identity?.Name ?? "Nội bộ")</span>
                            <a class="btn btn-accent" asp-controller="Cars" asp-action="Create">Đăng xe mới</a>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light">Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-accent" asp-controller="Account" asp-action="Login">Đăng nhập nội bộ</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container layout-shell">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success app-alert" role="alert">
                @successMessage
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger app-alert" role="alert">
                @errorMessage
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (showChatbot)
    {
        <div class="chatbot-shell"
             data-chatbot
             data-endpoint="@Url.Action("Ask", "Chatbot")"
             data-current-car-id="@(currentChatbotCarId?.ToString() ?? string.Empty)"
             data-csrf-token="@chatbotRequestToken">
            <button type="button"
                    class="chatbot-toggle"
                    data-chatbot-toggle
                    aria-expanded="false"
                    aria-controls="customer-chatbot">
                AI tư vấn xe
            </button>

            <section class="chatbot-panel" id="customer-chatbot" data-chatbot-panel hidden>
                <div class="chatbot-panel__header">
                    <div>
                        <span class="section-kicker">Hỗ trợ khách hàng</span>
                        <h2>AI tư vấn showroom</h2>
                    </div>
                    <button type="button" class="chatbot-close" data-chatbot-close aria-label="Đóng chatbot">×</button>
                </div>

                <div class="chatbot-messages" data-chatbot-messages>
                    <article class="chatbot-message chatbot-message--assistant">
                        Em có thể gợi ý xe theo ngân sách, so sánh mẫu xe đang có, giải thích thanh toán hoặc hỗ trợ đặt lịch xem xe ngay trong chat.
                    </article>
                </div>

                <div class="chatbot-prompts">
                    <button type="button" class="chatbot-prompt" data-chatbot-prompt="Gợi ý xe gia đình dưới 1 tỷ">Xe gia đình dưới 1 tỷ</button>
                    <button type="button" class="chatbot-prompt" data-chatbot-prompt="Gợi ý sedan đi làm hằng ngày">Sedan đi làm</button>
                    <button type="button" class="chatbot-prompt" data-chatbot-prompt="Showroom có những phương thức thanh toán nào?">Thanh toán</button>
                </div>

                <form class="chatbot-form" data-chatbot-form>
                    <input type="text"
                           class="form-control"
                           data-chatbot-input
                           placeholder="Ví dụ: SUV dưới 1 tỷ, xe gia đình 7 chỗ, đặt lịch xem Camry..." />
                    <button type="submit" class="btn btn-accent" data-chatbot-submit>Gửi</button>
                </form>
            </section>
        </div>
    }

    <footer class="footer">
        <div class="container footer__inner">
            <div class="footer__copy">
                <strong>AutoCarShowroom</strong>
                <p class="mb-0">Website showroom ô tô phục vụ trưng bày xe, tư vấn và đặt lịch xem xe cho đồ án môn học.</p>
            </div>
            <div class="footer__links">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Cars" asp-action="Index">Xem xe</a>
                <a asp-controller="Home" asp-action="Privacy">Thông tin hệ thống</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
