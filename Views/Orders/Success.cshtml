@model OrderSuccessViewModel

@{
    ViewData["Title"] = "Đặt mua xe thành công";
    var item = Model.Items.FirstOrDefault();
    var paymentInfo = OrderWorkflow.GetPaymentMethodInfo(Model.Order.PaymentMethod);
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Hoàn tất</span>
            <h1>Yêu cầu mua xe đã được ghi nhận</h1>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-light">Xem thêm xe khác</a>
    </div>

    <div class="success-layout">
        <div class="detail-list">
            <div class="detail-list__item">
                <span>Mã đơn mua</span>
                <strong>@Model.Order.OrderCode</strong>
            </div>
            <div class="detail-list__item">
                <span>Khách hàng</span>
                <strong>@Model.Order.CustomerName</strong>
            </div>
            <div class="detail-list__item">
                <span>Phương thức thanh toán</span>
                <strong>@Model.Order.PaymentMethod</strong>
            </div>
            <div class="detail-list__item">
                <span>Trạng thái đơn</span>
                <strong>@Model.Order.OrderStatus</strong>
            </div>
            <div class="detail-list__item">
                <span>Trạng thái thanh toán</span>
                <strong>@Model.Order.PaymentStatus</strong>
            </div>
            <div class="detail-list__item">
                <span>Tổng tiền</span>
                <strong>@Model.Order.TotalAmount.ToString("N0") VNĐ</strong>
            </div>
            <div class="detail-list__item">
                <span>Ngày tạo</span>
                <strong>@Model.Order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
        </div>

        <div class="summary-panel">
            <span class="section-kicker">Thanh toán</span>
            <h2>@paymentInfo.ShortLabel</h2>
            <p class="checkout-note">@paymentInfo.Description</p>

            @if (OrderWorkflow.UsesTransferInstructions(Model.Order.PaymentMethod))
            {
                <div class="payment-reference-card">
                    <div class="summary-row">
                        <span>Ngân hàng</span>
                        <strong>Vietcombank</strong>
                    </div>
                    <div class="summary-row">
                        <span>Số tài khoản</span>
                        <strong>1020202626</strong>
                    </div>
                    <div class="summary-row">
                        <span>Chủ tài khoản</span>
                        <strong>AUTO CAR SHOWROOM</strong>
                    </div>
                    <div class="summary-row">
                        <span>Nội dung chuyển khoản</span>
                        <strong>@Model.Order.OrderCode</strong>
                    </div>
                </div>
            }
            else
            {
                <div class="payment-reference-card">
                    @foreach (var step in paymentInfo.Steps)
                    {
                        <p class="payment-reference-card__line">@step</p>
                    }
                </div>
            }

            @if (item != null)
            {
                <div class="checkout-items mt-3">
                    <article class="checkout-item">
                        <img src="@item.CarImage" alt="@item.CarName" class="checkout-item__image" />
                        <div>
                            <h3>@item.CarName</h3>
                            <p class="cart-item-card__price">@item.UnitPrice.ToString("N0") VNĐ</p>
                        </div>
                    </article>
                </div>
            }

            <p class="checkout-note">Nhân viên nội bộ sẽ tiếp tục kiểm tra giao dịch, xác nhận tình trạng thanh toán và cập nhật đơn mua của bạn trong hệ thống.</p>
        </div>
    </div>
</section>
