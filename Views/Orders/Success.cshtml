@model OrderSuccessViewModel

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Hoàn tất</span>
            <h1>Đơn đặt xe đã được ghi nhận</h1>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-light">Xem thêm xe khác</a>
    </div>

    <div class="success-layout">
        <div class="detail-list">
            <div class="detail-list__item">
                <span>Mã đơn hàng</span>
                <strong>@Model.Order.OrderCode</strong>
            </div>
            <div class="detail-list__item">
                <span>Khách hàng</span>
                <strong>@Model.Order.CustomerName</strong>
            </div>
            <div class="detail-list__item">
                <span>Trạng thái đơn</span>
                <strong>@Model.Order.OrderStatus</strong>
            </div>
            <div class="detail-list__item">
                <span>Trạng thái thanh toán</span>
                <strong>@Model.Order.PaymentStatus</strong>
            </div>
            <div class="detail-list__item">
                <span>Tổng tiền</span>
                <strong>@Model.Order.TotalAmount.ToString("N0") VNĐ</strong>
            </div>
            <div class="detail-list__item">
                <span>Ngày tạo</span>
                <strong>@Model.Order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
        </div>

        <div class="summary-panel">
            <span class="section-kicker">Mẫu xe trong đơn</span>
            <div class="checkout-items mt-3">
                @foreach (var item in Model.Items)
                {
                    <article class="checkout-item">
                        <img src="@item.CarImage" alt="@item.CarName" class="checkout-item__image" />
                        <div>
                            <h3>@item.CarName</h3>
                            <p class="cart-item-card__price">@item.UnitPrice.ToString("N0") VNĐ</p>
                        </div>
                    </article>
                }
            </div>
            <p class="checkout-note">Quản trị viên sẽ tiếp tục kiểm tra và cập nhật trạng thái đơn hàng trong hệ thống.</p>
        </div>
    </div>
</section>
