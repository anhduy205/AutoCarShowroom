@model CheckoutViewModel

@{
    ViewData["Title"] = "Mua xe";
    ViewData["ChatbotCurrentCarId"] = Model.CarId;
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Thanh toán</span>
            <h1>Mua xe trực tiếp</h1>
        </div>
        <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.CarId" class="btn btn-outline-light">Quay lại xe</a>
    </div>

    <div class="checkout-layout">
        <div class="checkout-panel">
            <span class="section-kicker">Thông tin khách hàng</span>
            <form asp-action="Checkout" method="post" class="app-form mt-4">
                @Html.AntiForgeryToken()
                <input asp-for="CarId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label"></label>
                        <input asp-for="CustomerName" class="form-control" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" type="tel" inputmode="numeric" autocomplete="tel-national" maxlength="10" minlength="10" pattern="0[0-9]{9}" placeholder="09xxxxxxxx" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PaymentMethod" class="form-label"></label>
                        <select asp-for="PaymentMethod"
                                asp-items="ViewBag.PaymentMethods"
                                class="form-select"
                                data-payment-select></select>
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Note" class="form-label"></label>
                        <textarea asp-for="Note" class="form-control" rows="4" placeholder="Ví dụ: muốn nhận cuộc gọi xác nhận vào buổi chiều, cần hỗ trợ xuất hóa đơn..."></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                </div>

                <div class="payment-method-grid mt-4">
                    @foreach (var paymentInfo in OrderWorkflow.PublicPaymentMethodInfos)
                    {
                        var isActive = string.Equals(paymentInfo.Value, Model.PaymentMethod, StringComparison.OrdinalIgnoreCase);

                        <article class="payment-method-card @(isActive ? "is-active" : string.Empty)" data-payment-card="@paymentInfo.Value">
                            <div class="payment-method-card__header">
                                <strong>@paymentInfo.ShortLabel</strong>
                                <span>@paymentInfo.Highlight</span>
                            </div>
                            <p>@paymentInfo.Description</p>
                            <ul class="payment-method-card__list">
                                @foreach (var step in paymentInfo.Steps)
                                {
                                    <li>@step</li>
                                }
                            </ul>
                        </article>
                    }
                </div>

                <div class="checkout-submit">
                    <button type="submit" class="btn btn-accent">Gửi yêu cầu mua xe</button>
                </div>
            </form>
        </div>

        <aside class="summary-panel">
            <span class="section-kicker">Tóm tắt xe</span>
            <h2>Mẫu xe đang xử lý mua</h2>
            <div class="checkout-items">
                <article class="checkout-item">
                    <img src="@Model.Car.Image" alt="@Model.Car.CarName" class="checkout-item__image" />
                    <div>
                        <p class="car-card__eyebrow">@Model.Car.Brand @Model.Car.ModelName</p>
                        <h3>@Model.Car.CarName</h3>
                        <p class="cart-item-card__price">@Model.Car.Price.ToString("N0") VNĐ</p>
                        @if (!string.IsNullOrWhiteSpace(Model.Car.AvailabilityMessage))
                        {
                            <p class="checkout-note">@Model.Car.AvailabilityMessage</p>
                        }
                    </div>
                </article>
            </div>
            <div class="summary-row">
                <span>Tổng thanh toán</span>
                <strong>@Model.TotalAmount.ToString("N0") VNĐ</strong>
            </div>
            <p class="checkout-note">Nếu anh/chị cần thêm phương án thanh toán khác, showroom sẽ tư vấn riêng sau khi tiếp nhận nhu cầu.</p>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
