@model CarFormViewModel

@{
    ViewData["Title"] = "Chinh sua xe";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Cap nhat du lieu</span>
            <h1>Chinh sua thong tin xe</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai danh sach</a>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data" class="app-form">
        <input type="hidden" asp-for="CarID" />
        <partial name="_CarFormFields" model="Model" />

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-dark">Luu thay doi</button>
            <a asp-action="Details" asp-route-id="@Model.CarID" class="btn btn-outline-secondary">Xem chi tiet</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
