@model CarFormViewModel

@{
    ViewData["Title"] = "Them xe";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Quan ly xe</span>
            <h1>Them xe moi</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai danh sach</a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data" class="app-form">
        <partial name="_CarFormFields" model="Model" />

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-dark">Luu xe</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
