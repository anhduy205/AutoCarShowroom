@model Car

@using System.Text.RegularExpressions

@{
    ViewData["Title"] = "Chi tiết xe";
    ViewData["ChatbotCurrentCarId"] = Model.CarID;

    var canOrder = OrderWorkflow.CanOrder(Model);
    var isBackOffice = InternalAccess.IsBackOffice(User);
    var statusClass = Model.Status switch
    {
        var status when status == OrderWorkflow.CarStatusSold => "status-badge status-badge--sold",
        var status when status == OrderWorkflow.CarStatusPromotion => "status-badge status-badge--promo",
        _ => "status-badge status-badge--available"
    };

    string NormalizeCopy(string? content, string fallback)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return fallback;
        }

        var normalized = Regex.Replace(content, @"\s*\r?\n\s*", "\n");
        normalized = Regex.Replace(normalized, @"[^\S\r\n]+", " ");
        return normalized.Trim();
    }

    var detailSections = new[]
    {
        new { Title = "Thông tin chung", Content = NormalizeCopy(Model.Specifications, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "Động cơ & khung gầm", Content = NormalizeCopy(Model.EngineAndChassis, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "Ngoại thất", Content = NormalizeCopy(Model.Exterior, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "Nội thất", Content = NormalizeCopy(Model.Interior, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "Ghế", Content = NormalizeCopy(Model.Seats, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "Tiện nghi", Content = NormalizeCopy(Model.Convenience, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "An ninh / chống trộm", Content = NormalizeCopy(Model.SecurityAndAntiTheft, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "An toàn chủ động", Content = NormalizeCopy(Model.ActiveSafety, "Showroom đang cập nhật thêm thông tin ở mục này.") },
        new { Title = "An toàn bị động", Content = NormalizeCopy(Model.PassiveSafety, "Showroom đang cập nhật thêm thông tin ở mục này.") }
    };
}

<section class="detail-hero">
    <div class="detail-hero__media">
        <img src="@Model.Image" alt="@Model.CarName" class="detail-hero__image" />
    </div>

    <div class="detail-hero__content">
        <span class="section-kicker">Chi tiết mẫu xe</span>
        <p class="detail-hero__eyebrow">@Model.Brand @Model.ModelName</p>
        <h1>@Model.CarName</h1>
        <div class="detail-hero__specs">
            <span class="pill">@Model.BodyType</span>
            <span class="pill">Màu @Model.Color</span>
            <span class="pill">Đời @Model.Year</span>
            <span class="@statusClass">@Model.Status</span>
        </div>

        <div class="price-banner">@Model.Price.ToString("N0") VNĐ</div>
        <p class="detail-hero__description copy-safe">@NormalizeCopy(Model.Description, "Showroom đang cập nhật thêm mô tả cho mẫu xe này.")</p>

        <div class="detail-hero__actions">
            <a asp-action="Index" class="btn btn-outline-dark">Quay lại danh sách xe</a>
            @if (isBackOffice)
            {
                <a asp-action="Edit" asp-route-id="@Model.CarID" class="btn btn-accent">Chỉnh sửa mẫu xe</a>
                <a asp-action="Delete" asp-route-id="@Model.CarID" class="btn btn-outline-danger">Xóa xe</a>
            }
            else if (canOrder)
            {
                <a asp-controller="Orders" asp-action="Checkout" asp-route-carId="@Model.CarID" class="btn btn-accent">Mua xe</a>
                <a asp-controller="Bookings" asp-action="Create" asp-route-carId="@Model.CarID" class="btn btn-outline-dark">Đặt lịch xem xe</a>
            }
            else
            {
                <button type="button" class="btn btn-outline-dark" disabled>Xe đã bán hoặc tạm ngưng nhận khách</button>
            }
        </div>
    </div>
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Tổng quan</span>
            <h2>Thông tin nhanh</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="detail-list">
                <div class="detail-list__item">
                    <span>Hãng xe</span>
                    <strong>@Model.Brand</strong>
                </div>
                <div class="detail-list__item">
                    <span>Dòng xe</span>
                    <strong>@Model.ModelName</strong>
                </div>
                <div class="detail-list__item">
                    <span>Tên xe hiển thị</span>
                    <strong>@Model.CarName</strong>
                </div>
                <div class="detail-list__item">
                    <span>Loại xe</span>
                    <strong>@Model.BodyType</strong>
                </div>
                <div class="detail-list__item">
                    <span>Màu sắc</span>
                    <strong>@Model.Color</strong>
                </div>
                <div class="detail-list__item">
                    <span>Trạng thái</span>
                    <strong>@Model.Status</strong>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="spec-panel spec-panel--summary h-100">
                <span class="section-kicker">Mô tả nổi bật</span>
                <p class="spec-panel__text copy-safe">@NormalizeCopy(Model.Description, "Showroom đang cập nhật thêm mô tả cho mẫu xe này.")</p>
            </div>
        </div>
    </div>
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Thông số</span>
            <h2>Chi tiết từng hạng mục</h2>
        </div>
    </div>

    <div class="detail-section-grid">
        @foreach (var detailSection in detailSections)
        {
            <article class="detail-section-card">
                <h3>@detailSection.Title</h3>
                <p class="copy-safe">@detailSection.Content</p>
            </article>
        }
    </div>
</section>
