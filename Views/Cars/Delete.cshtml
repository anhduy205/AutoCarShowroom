@model Car

@{
    ViewData["Title"] = "Xoa xe";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Xac nhan thao tac</span>
            <h1>Xoa xe khoi he thong</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai danh sach</a>
    </div>

    <div class="detail-panel">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                <img src="@Model.Image" alt="@Model.CarName" class="detail-panel__image" />
            </div>
            <div class="col-lg-7">
                <h2>@Model.CarName</h2>
                <p class="text-muted">Ban sap xoa mau xe nay khoi showroom. Thao tac nay khong the hoan tac.</p>

                <div class="detail-list mt-4">
                    <div class="detail-list__item">
                        <span>Hang xe</span>
                        <strong>@Model.Brand</strong>
                    </div>
                    <div class="detail-list__item">
                        <span>Gia ban</span>
                        <strong>@Model.Price.ToString("N0") VND</strong>
                    </div>
                    <div class="detail-list__item">
                        <span>Nam san xuat</span>
                        <strong>@Model.Year</strong>
                    </div>
                </div>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="CarID" />
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-danger">Xac nhan xoa</button>
                        <a asp-action="Details" asp-route-id="@Model.CarID" class="btn btn-outline-secondary">Huy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
