@model AutoCarShowroom.ViewModels.CarCatalogIndexViewModel

@{
    ViewData["Title"] = "Bộ sưu tập xe";
    var currentSearch = ViewData["CurrentSearch"] as string;
}

<section class="inventory-hero">
    <div class="inventory-hero__copy">
        <span class="section-kicker">Danh mục theo dòng xe</span>
        <h1>Chọn theo dòng xe trước, rồi xem từng phiên bản bên trong.</h1>
        <p>Thay vì trải toàn bộ 170 xe lên một trang, showroom giờ gom theo từng dòng để dễ xem hơn, dễ so sánh hơn và giống cách các hãng xe đang trưng bày.</p>
        <div class="hero-showcase__tags">
            <span>@Model.TotalLines dòng xe</span>
            <span>@Model.TotalVariants phiên bản</span>
            <span>Bấm vào từng dòng để xem chi tiết</span>
        </div>
    </div>

    <div class="inventory-hero__panel">
        <span class="inventory-hero__label">Cách xem mới</span>
        <strong>Xem theo dòng xe trước</strong>
        <p>Mỗi dòng sẽ có trang riêng, các phiên bản nằm cùng một chỗ để bạn bấm chọn trực tiếp và so sánh nhanh.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="Create" class="btn btn-accent">Đăng thêm phiên bản mới</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="btn btn-accent">Về trang chủ</a>
        }
    </div>
</section>

@if (ViewData["LoadError"] is string loadError)
{
    <div class="alert alert-warning app-alert" role="alert">
        @loadError
    </div>
}

<form asp-action="Index" method="get" class="filter-panel">
    <div class="filter-bar">
        <div class="filter-field filter-field--search">
            <label class="form-label" for="searchTerm">Tìm kiếm</label>
            <input id="searchTerm" name="searchTerm" value="@currentSearch" class="form-control" placeholder="911, Tucson, Ferrari..." />
        </div>
        <div class="filter-field">
            <label class="form-label" for="brand">Hãng xe</label>
            <select id="brand" name="brand" class="form-select" asp-items="ViewBag.Brands">
                <option value="">Tất cả hãng</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="bodyType">Loại xe</label>
            <select id="bodyType" name="bodyType" class="form-select" asp-items="ViewBag.BodyTypeFilters">
                <option value="">Tất cả loại xe</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="priceRange">Khoảng giá</label>
            <select id="priceRange" name="priceRange" class="form-select" asp-items="ViewBag.PriceRanges">
                <option value="">Tất cả mức giá</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="status">Trạng thái</label>
            <select id="status" name="status" class="form-select" asp-items="ViewBag.StatusFilters">
                <option value="">Tất cả trạng thái</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="year">Năm</label>
            <select id="year" name="year" class="form-select" asp-items="ViewBag.Years">
                <option value="">Tất cả năm</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="sortOrder">Sắp xếp</label>
            <select id="sortOrder" name="sortOrder" class="form-select" asp-items="ViewBag.SortOptions"></select>
        </div>
        <div class="filter-field filter-field--actions d-flex gap-2">
            <button type="submit" class="btn btn-accent">Áp dụng</button>
            <a asp-action="Index" class="btn btn-outline-dark">Đặt lại</a>
        </div>
    </div>
</form>

@if (Model.Lines.Any())
{
    <section class="line-grid">
        @foreach (var line in Model.Lines)
        {
            <article class="line-card">
                <div class="line-card__media">
                    <img src="@line.Image" alt="@line.DisplayName" class="line-card__image" />
                </div>

                <div class="line-card__body">
                    <div class="line-card__meta">
                        <span class="pill">@line.BodyType</span>
                        <span class="pill">@line.VariantCount phiên bản</span>
                        <span class="pill">@line.NewestYear</span>
                    </div>

                    <p class="car-card__eyebrow">@line.Brand</p>
                    <h2>@line.ModelName</h2>
                    <p class="line-card__highlight">@line.Highlight</p>
                    <p class="line-card__accent">@line.AccentLine</p>

                    <div class="line-card__pricing">
                        <strong>@line.PriceFrom.ToString("N0") - @line.PriceTo.ToString("N0") VNĐ</strong>
                        <span>Khoảng giá toàn dòng</span>
                    </div>

                    <div class="line-card__actions">
                        <a asp-action="Line"
                           asp-route-brand="@line.Brand"
                           asp-route-modelName="@line.ModelName"
                           asp-route-variantId="@line.RepresentativeCarId"
                           class="btn btn-accent">
                            Khám phá dòng xe
                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-action="Edit" asp-route-id="@line.RepresentativeCarId" class="btn btn-outline-dark">Sửa bản đại diện</a>
                        }
                    </div>
                </div>
            </article>
        }
    </section>
}
else
{
    <div class="empty-state">
        <h2>Chưa tìm thấy dòng xe phù hợp</h2>
        <p>Thử đổi bộ lọc hoặc từ khóa để mở rộng kết quả tìm kiếm.</p>
        <a asp-action="Index" class="btn btn-accent">Xem lại toàn bộ danh mục</a>
    </div>
}
