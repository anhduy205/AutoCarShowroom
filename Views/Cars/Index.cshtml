@model AutoCarShowroom.ViewModels.CarCatalogIndexViewModel

@using System.Text.RegularExpressions

@{
    ViewData["Title"] = "Xem xe";
    var currentSearch = ViewData["CurrentSearch"] as string;
    var isBackOffice = InternalAccess.IsBackOffice(User);

    string GetStatusClass(string status) => status switch
    {
        var value when value == OrderWorkflow.CarStatusSold => "status-badge status-badge--sold",
        var value when value == OrderWorkflow.CarStatusPromotion => "status-badge status-badge--promo",
        _ => "status-badge status-badge--available"
    };

    string NormalizeCopy(string? content, string fallback)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return fallback;
        }

        var normalized = Regex.Replace(content, @"\s*\r?\n\s*", "\n");
        normalized = Regex.Replace(normalized, @"[^\S\r\n]+", " ");
        return normalized.Trim();
    }

    string GetSummary(string? content)
    {
        var normalized = NormalizeCopy(content, "Thông tin đang được cập nhật để khách xem nhanh hơn.");
        var parts = normalized.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 0 ? normalized : $"{parts[0].Trim()}.";
    }
}

<section class="inventory-hero">
    <div class="inventory-hero__copy">
        <span class="section-kicker">Danh mục showroom</span>
        <h1>Kho xe đang mở bán</h1>
        <p class="copy-safe copy-safe--compact">Xem nhanh từng mẫu xe, lọc theo nhu cầu và thao tác trực tiếp ngay trên mỗi thẻ sản phẩm.</p>
        <div class="hero-showcase__tags">
            <span>@Model.TotalVariants mẫu xe</span>
            <span>@Model.TotalLines dòng xe</span>
            <span>Thao tác trực tiếp trên từng xe</span>
        </div>
    </div>

    <div class="inventory-hero__panel">
        <span class="inventory-hero__label">Trải nghiệm</span>
        <strong>Dễ xem, dễ chọn, dễ đặt lịch</strong>
        <p class="copy-safe copy-safe--compact">Ảnh xe rõ hơn, giá dễ nhìn hơn và bộ lọc gọn hơn để khách thao tác nhanh.</p>
        @if (isBackOffice)
        {
            <a asp-action="Create" class="btn btn-accent">Đăng thêm mẫu xe mới</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="btn btn-accent">Về trang chủ</a>
        }
    </div>
</section>

@if (ViewData["LoadError"] is string loadError)
{
    <div class="alert alert-warning app-alert" role="alert">
        @loadError
    </div>
}

<form asp-action="Index" method="get" class="filter-panel">
    <div class="filter-bar">
        <div class="filter-field filter-field--search">
            <label class="form-label" for="searchTerm">Tìm kiếm</label>
            <input id="searchTerm" name="searchTerm" value="@currentSearch" class="form-control" placeholder="Camry, Tucson, Ferrari, VinFast..." />
        </div>
        <div class="filter-field">
            <label class="form-label" for="brand">Hãng xe</label>
            <select id="brand" name="brand" class="form-select" asp-items="ViewBag.Brands">
                <option value="">Tất cả hãng</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="bodyType">Loại xe</label>
            <select id="bodyType" name="bodyType" class="form-select" asp-items="ViewBag.BodyTypeFilters">
                <option value="">Tất cả loại xe</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="priceRange">Khoảng giá</label>
            <select id="priceRange" name="priceRange" class="form-select" asp-items="ViewBag.PriceRanges">
                <option value="">Tất cả mức giá</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="status">Trạng thái</label>
            <select id="status" name="status" class="form-select" asp-items="ViewBag.StatusFilters">
                <option value="">Tất cả trạng thái</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="year">Năm</label>
            <select id="year" name="year" class="form-select" asp-items="ViewBag.Years">
                <option value="">Tất cả năm</option>
            </select>
        </div>
        <div class="filter-field">
            <label class="form-label" for="sortOrder">Sắp xếp</label>
            <select id="sortOrder" name="sortOrder" class="form-select" asp-items="ViewBag.SortOptions"></select>
        </div>
        <div class="filter-field filter-field--actions d-flex gap-2">
            <button type="submit" class="btn btn-accent">Áp dụng</button>
            <a asp-action="Index" class="btn btn-outline-dark">Đặt lại</a>
        </div>
    </div>
</form>

@if (Model.Cars.Any())
{
    <div class="row g-4">
        @foreach (var car in Model.Cars)
        {
            var statusClass = GetStatusClass(car.Status);
            var canOrder = OrderWorkflow.CanOrder(car);

            <div class="col-md-6 col-xl-4">
                <article class="car-card">
                    <img src="@car.Image" alt="@car.CarName" class="car-card__image" />

                    <div class="car-card__body">
                        <div class="car-card__meta">
                            <div class="car-card__tag-group">
                                <span class="pill">@car.BodyType</span>
                                <span class="pill">@car.Color</span>
                                <span class="pill">@car.Year</span>
                            </div>
                            <span class="@statusClass">@car.Status</span>
                        </div>

                        <p class="car-card__eyebrow">@car.Brand · @car.ModelName</p>
                        <h3>@car.CarName</h3>
                        <p class="car-card__subtitle copy-safe copy-safe--compact">@GetSummary(car.Description)</p>
                        <div class="car-card__price">@car.Price.ToString("N0") VNĐ</div>

                        <div class="car-card__actions">
                            <a asp-action="Details" asp-route-id="@car.CarID" class="btn btn-outline-dark">Xem xe</a>

                            @if (isBackOffice)
                            {
                                <a asp-action="Edit" asp-route-id="@car.CarID" class="btn btn-accent">Sửa xe</a>
                                <a asp-action="Delete" asp-route-id="@car.CarID" class="btn btn-outline-danger">Xóa xe</a>
                            }
                            else if (canOrder)
                            {
                                <a asp-controller="Orders" asp-action="Checkout" asp-route-carId="@car.CarID" class="btn btn-accent">Mua xe</a>
                                <a asp-controller="Bookings" asp-action="Create" asp-route-carId="@car.CarID" class="btn btn-outline-dark">Đặt lịch xem xe</a>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-dark" disabled>Xe đã bán hoặc tạm ngưng</button>
                            }
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <h2>Chưa tìm thấy mẫu xe phù hợp</h2>
        <p class="copy-safe copy-safe--compact">Thử đổi bộ lọc hoặc từ khóa để mở rộng kết quả tìm kiếm.</p>
        <a asp-action="Index" class="btn btn-accent">Xem lại toàn bộ xe</a>
    </div>
}
