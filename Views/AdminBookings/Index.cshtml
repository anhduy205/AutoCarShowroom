@model IEnumerable<Booking>

@{
    ViewData["Title"] = "Quản lý khách đặt lịch";

    string GetBookingStatusClass(string status) => status switch
    {
        var value when value == BookingWorkflow.StatusPendingConfirmation => "table-status-badge table-status-badge--pending",
        var value when value == BookingWorkflow.StatusConfirmed => "table-status-badge table-status-badge--confirmed",
        var value when value == BookingWorkflow.StatusRejected => "table-status-badge table-status-badge--rejected",
        var value when value == BookingWorkflow.StatusRescheduleRequested => "table-status-badge table-status-badge--reschedule",
        var value when value == BookingWorkflow.StatusVisited => "table-status-badge table-status-badge--visited",
        var value when value == BookingWorkflow.StatusSold => "table-status-badge table-status-badge--sold",
        var value when value == BookingWorkflow.StatusUnsuccessful => "table-status-badge table-status-badge--unsuccessful",
        _ => "table-status-badge table-status-badge--cancelled"
    };
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Quản trị</span>
            <h1>Danh sách khách đặt lịch</h1>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-dark">Quay lại kho xe</a>
    </div>

    @if (Model.Any())
    {
        <div class="table-shell">
            <table class="app-table">
                <thead>
                    <tr>
                        <th>Mã lịch</th>
                        <th>Khách hàng</th>
                        <th>Mẫu xe</th>
                        <th>Dịch vụ</th>
                        <th>Ngày giờ hẹn</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td><strong>@booking.BookingCode</strong></td>
                            <td>
                                <strong>@booking.CustomerName</strong>
                                <div class="table-subtitle">@booking.PhoneNumber</div>
                            </td>
                            <td>
                                <strong>@booking.CarName</strong>
                                <div class="table-subtitle">@booking.Email</div>
                            </td>
                            <td>@booking.ServiceType</td>
                            <td>@booking.AppointmentAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="@GetBookingStatusClass(booking.BookingStatus)">@booking.BookingStatus</span></td>
                            <td>@booking.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@booking.BookingId" class="btn btn-outline-dark btn-sm">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2>Chưa có lịch hẹn nào</h2>
            <p class="copy-safe copy-safe--compact">Khách đặt lịch xem xe sẽ hiển thị tại đây để bộ phận showroom theo dõi và xác nhận.</p>
        </div>
    }
</section>
