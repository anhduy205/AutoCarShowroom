@inject Microsoft.Extensions.Options.IOptions<AutoCarShowroom.Models.AdminAccountOptions> AdminOptions

@{
    ViewData["Title"] = "Thong tin do an";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Bao cao tom tat</span>
            <h1>@ViewData["Title"]</h1>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-secondary">Mo showroom</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <article class="info-card h-100">
                <h2>Muc tieu</h2>
                <p>Xay dung website showroom xe su dung ASP.NET Core MVC de quan ly danh sach xe, hinh anh va thong tin chi tiet.</p>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="info-card h-100">
                <h2>Cong nghe</h2>
                <p>ASP.NET Core MVC, Entity Framework Core, SQL Server, Bootstrap va cookie authentication cho khu admin.</p>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="info-card h-100">
                <h2>Chuc nang</h2>
                <p>Xem showroom cong khai, dang nhap admin, them sua xoa xe, upload anh that, tim kiem, loc va sap xep danh sach.</p>
            </article>
        </div>
    </div>
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Demo</span>
            <h2>Noi dung trinh bay khi bao cao</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <article class="info-card h-100">
                <h3>Luong nguoi dung</h3>
                <p>Khach truy cap co the xem danh sach xe, loc theo nam, tim theo ten va xem chi tiet tung mau xe.</p>
            </article>
        </div>
        <div class="col-md-6">
            <article class="info-card h-100">
                <h3>Luong quan tri</h3>
                <p>Sau khi dang nhap tai khoan <strong>@AdminOptions.Value.Username</strong>, admin co the them, sua, xoa xe va thay doi anh bang file upload.</p>
            </article>
        </div>
        <div class="col-md-6">
            <article class="info-card h-100">
                <h3>Du lieu mau</h3>
                <p>He thong tu seed san danh sach xe demo luc khoi dong neu database chua co du lieu, giup ban demo ngay sau khi chay app.</p>
            </article>
        </div>
        <div class="col-md-6">
            <article class="info-card h-100">
                <h3>Huong mo rong</h3>
                <p>Co the phat trien them dat lich xem xe, thong ke doanh thu, phan quyen nhieu vai tro va luu lich su cap nhat.</p>
            </article>
        </div>
    </div>
</section>
