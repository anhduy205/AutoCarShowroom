@inject Microsoft.Extensions.Options.IOptions<AutoCarShowroom.Models.AdminAccountOptions> AdminOptions

@{
    ViewData["Title"] = "Giới thiệu đồ án";
}

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Giới thiệu hệ thống</span>
            <h1>@ViewData["Title"]</h1>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-accent">Mở showroom</a>
    </div>

    <div class="service-grid">
        <article class="service-card">
            <span class="service-card__number">01</span>
            <h3>Mục tiêu đồ án</h3>
            <p>Xây dựng website showroom ô tô với giao diện hiện đại, khả năng quản trị nội dung và trưng bày xe trực quan.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">02</span>
            <h3>Công nghệ sử dụng</h3>
            <p>ASP.NET Core MVC, Entity Framework Core, SQL Server, cookie authentication và giao diện tuỳ biến bằng CSS.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">03</span>
            <h3>Luồng quản trị</h3>
            <p>Tài khoản quản trị mặc định là <strong>@AdminOptions.Value.Username</strong>, cho phép đăng xe, sửa nội dung và cập nhật hình ảnh.</p>
        </article>
    </div>
</section>

<section class="section-block section-block--dark">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Điểm nhấn thuyết trình</span>
            <h2>Những nội dung bạn có thể trình bày khi báo cáo</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <article class="car-card car-card--dark h-100">
                <div class="car-card__body">
                    <h3>Giao diện phong cách web xe</h3>
                    <p>Trang chủ và trang danh mục đã được thiết kế theo cảm hứng showroom ô tô với ảnh lớn, màu sắc cao cấp và nhịp bố cục rõ ràng.</p>
                </div>
            </article>
        </div>
        <div class="col-md-6">
            <article class="car-card car-card--dark h-100">
                <div class="car-card__body">
                    <h3>Việt hoá toàn bộ hệ thống</h3>
                    <p>Mọi nút bấm, tiêu đề, mô tả và thông báo người dùng chính đều đã được chuyển sang tiếng Việt có dấu.</p>
                </div>
            </article>
        </div>
        <div class="col-md-6">
            <article class="car-card car-card--dark h-100">
                <div class="car-card__body">
                    <h3>Quản trị viên thao tác trực tiếp</h3>
                    <p>Đăng nhập để thêm xe, tải ảnh thật từ máy, cập nhật thông tin và xoá xe khỏi hệ thống.</p>
                </div>
            </article>
        </div>
        <div class="col-md-6">
            <article class="car-card car-card--dark h-100">
                <div class="car-card__body">
                    <h3>Dữ liệu mẫu để demo</h3>
                    <p>Nếu cơ sở dữ liệu đang trống, hệ thống có thể seed dữ liệu để bạn trình bày ngay luồng hiển thị và quản trị.</p>
                </div>
            </article>
        </div>
    </div>
</section>
