@using System.Linq
@model HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
    var featuredCar = Model.FeaturedCars.FirstOrDefault();
}

<section class="hero-showcase">
    <div class="hero-showcase__copy">
        <span class="section-kicker">Showroom ô tô</span>
        <h1>Chọn mẫu xe đẹp, rõ giá, mua nhanh hoặc đặt lịch dễ dàng.</h1>
        <p class="hero-showcase__description">
            Website tập trung vào trải nghiệm xem xe, mua xe trực tiếp và đặt lịch hẹn với showroom.
        </p>

        <div class="hero-showcase__actions">
            <a asp-controller="Cars" asp-action="Index" class="btn btn-accent btn-lg">Khám phá kho xe</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Cars" asp-action="Create" class="btn btn-outline-dark btn-lg">Đăng mẫu xe mới</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-dark btn-lg">Đăng nhập quản trị</a>
            }
        </div>

        <div class="hero-showcase__tags">
            <span>Mua xe trực tiếp</span>
            <span>Đặt lịch hẹn</span>
            <span>Quản lý doanh thu</span>
        </div>
    </div>

    <div class="hero-showcase__visual">
        @if (featuredCar != null)
        {
            var statusClass = featuredCar.Status switch
            {
                var status when status == OrderWorkflow.CarStatusSold => "status-badge status-badge--sold",
                var status when status == OrderWorkflow.CarStatusPromotion => "status-badge status-badge--promo",
                _ => "status-badge status-badge--available"
            };

            <article class="feature-card">
                <img src="@featuredCar.Image" alt="@featuredCar.CarName" class="feature-card__image" />
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">@featuredCar.Brand @featuredCar.ModelName</span>
                    <h2>@featuredCar.CarName</h2>
                    <div class="feature-card__meta">
                        <span class="pill">@featuredCar.BodyType</span>
                        <span class="pill">Màu @featuredCar.Color</span>
                        <span class="@statusClass">@featuredCar.Status</span>
                    </div>
                    <div class="feature-card__footer">
                        <strong>@featuredCar.Price.ToString("N0") VNĐ</strong>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@featuredCar.CarID" class="btn btn-light">Xem chi tiết</a>
                    </div>
                </div>
            </article>
        }
        else
        {
            <div class="feature-card feature-card--placeholder">
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">Showroom</span>
                    <h2>Sẵn sàng trưng bày mẫu xe đầu tiên</h2>
                    <p>Đăng nhập quản trị để thêm dữ liệu và hoàn thiện luồng demo cho đồ án của bạn.</p>
                </div>
            </div>
        }
    </div>
</section>

<section class="metrics-strip">
    <article class="metric-card">
        <span class="metric-card__label">Số lượng xe</span>
        <strong>@Model.TotalCars</strong>
        <p>Đang trưng bày.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Giá trung bình</span>
        <strong>@Model.AveragePrice.ToString("N0") VNĐ</strong>
        <p>Mốc tham khảo.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Đời xe mới nhất</span>
        <strong>@(Model.NewestModelYear == 0 ? "--" : Model.NewestModelYear)</strong>
        <p>Phiên bản mới.</p>
    </article>
</section>

@if (ViewData["LoadError"] is string loadError)
{
    <div class="alert alert-warning app-alert" role="alert">
        @loadError
    </div>
}

<section class="section-block section-block--dark">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Nổi bật</span>
            <h2>Mẫu xe đáng xem</h2>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-light">Xem toàn bộ danh mục</a>
    </div>

    @if (Model.FeaturedCars.Any())
    {
        <div class="row g-4">
            @foreach (var car in Model.FeaturedCars)
            {
                var canOrder = OrderWorkflow.CanOrder(car);
                var statusClass = car.Status switch
                {
                    var status when status == OrderWorkflow.CarStatusSold => "status-badge status-badge--sold",
                    var status when status == OrderWorkflow.CarStatusPromotion => "status-badge status-badge--promo",
                    _ => "status-badge status-badge--available"
                };

                <div class="col-md-6 col-xl-4">
                    <article class="car-card h-100">
                        <img src="@car.Image" alt="@car.CarName" class="car-card__image" />
                        <div class="car-card__body">
                            <div class="car-card__meta">
                                <div class="car-card__tag-group">
                                    <span class="pill">@car.BodyType</span>
                                    <span class="pill">@car.Year</span>
                                </div>
                                <span class="@statusClass">@car.Status</span>
                            </div>
                            <p class="car-card__eyebrow">@car.Brand @car.ModelName</p>
                            <h3>@car.CarName</h3>
                            <p class="car-card__subtitle">Màu sắc: @car.Color</p>
                            <div class="car-card__meta">
                                <span class="car-card__price">@car.Price.ToString("N0") VNĐ</span>
                            </div>
                            <div class="car-card__actions">
                                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarID" class="btn btn-outline-dark">Xem xe</a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-controller="Cars" asp-action="Edit" asp-route-id="@car.CarID" class="btn btn-accent">Chỉnh sửa</a>
                                }
                                else if (canOrder)
                                {
                                    <a asp-controller="Orders" asp-action="Checkout" asp-route-carId="@car.CarID" class="btn btn-accent">Mua xe</a>
                                    <a asp-controller="Bookings" asp-action="Create" asp-route-carId="@car.CarID" class="btn btn-outline-dark">Đặt lịch</a>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state empty-state--dark">
            <h3>Chưa có dữ liệu showroom</h3>
            <p>Đăng nhập để thêm xe.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-accent">Đăng nhập ngay</a>
        </div>
    }
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Điểm mạnh</span>
            <h2>Gọn, rõ, dễ dùng</h2>
        </div>
    </div>

    <div class="service-grid">
        <article class="service-card">
            <span class="service-card__number">01</span>
            <h3>Ảnh lớn</h3>
            <p>Nhìn xe rõ ngay trên màn hình.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">02</span>
            <h3>Lọc nhanh</h3>
            <p>Tìm xe dễ hơn theo hãng, giá và năm.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">03</span>
            <h3>Linh hoạt</h3>
            <p>Khách có thể mua xe trực tiếp hoặc đặt lịch xem xe.</p>
        </article>
    </div>
</section>
