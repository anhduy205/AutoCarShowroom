@using System.Linq
@model HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
    var xeNoiBat = Model.FeaturedCars.FirstOrDefault();
}

<section class="hero-showcase">
    <div class="hero-showcase__copy">
        <span class="section-kicker">Showroom ô tô</span>
        <h1>Chọn mẫu xe đẹp, rõ giá, xem nhanh.</h1>
        <p class="hero-showcase__description">
            Giao diện gọn, trực quan và dễ demo.
        </p>

        <div class="hero-showcase__actions">
            <a asp-controller="Cars" asp-action="Index" class="btn btn-accent btn-lg">Khám phá kho xe</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Cars" asp-action="Create" class="btn btn-outline-dark btn-lg">Đăng mẫu xe mới</a>
            }
            else
            {
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark btn-lg">Mở giỏ hàng</a>
            }
        </div>

        <div class="hero-showcase__tags">
            <span>SUV</span>
            <span>Sedan</span>
            <span>MPV</span>
        </div>
    </div>

    <div class="hero-showcase__visual">
        @if (xeNoiBat != null)
        {
            var statusClass = xeNoiBat.Status switch
            {
                "Đã bán" => "status-badge status-badge--sold",
                "Khuyến mãi" => "status-badge status-badge--promo",
                _ => "status-badge status-badge--available"
            };

            <article class="feature-card">
                <img src="@xeNoiBat.Image" alt="@xeNoiBat.CarName" class="feature-card__image" />
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">@xeNoiBat.Brand @xeNoiBat.ModelName</span>
                    <h2>@xeNoiBat.CarName</h2>
                    <div class="feature-card__meta">
                        <span class="pill">@xeNoiBat.BodyType</span>
                        <span class="pill">Màu @xeNoiBat.Color</span>
                        <span class="@statusClass">@xeNoiBat.Status</span>
                    </div>
                    <div class="feature-card__footer">
                        <strong>@xeNoiBat.Price.ToString("N0") VNĐ</strong>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@xeNoiBat.CarID" class="btn btn-light">Xem chi tiết</a>
                    </div>
                </div>
            </article>
        }
        else
        {
            <div class="feature-card feature-card--placeholder">
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">Showroom</span>
                    <h2>Sẵn sàng trưng bày mẫu xe đầu tiên</h2>
                    <p>Đăng nhập quản trị để thêm dữ liệu và bắt đầu hoàn thiện bài đồ án của bạn.</p>
                </div>
            </div>
        }
    </div>
</section>

<section class="metrics-strip">
    <article class="metric-card">
        <span class="metric-card__label">Số lượng xe</span>
        <strong>@Model.TotalCars</strong>
        <p>Đang trưng bày.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Giá trung bình</span>
        <strong>@Model.AveragePrice.ToString("N0") VNĐ</strong>
        <p>Mốc tham khảo.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Đời xe mới nhất</span>
        <strong>@(Model.NewestModelYear == 0 ? "--" : Model.NewestModelYear)</strong>
        <p>Phiên bản mới.</p>
    </article>
</section>

@if (ViewData["LoadError"] is string loadError)
{
    <div class="alert alert-warning app-alert" role="alert">
        @loadError
    </div>
}

<section class="section-block section-block--dark">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Nổi bật</span>
            <h2>Mẫu xe đáng xem</h2>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-light">Xem toàn bộ danh mục</a>
    </div>

    @if (Model.FeaturedCars.Any())
    {
        <div class="row g-4">
            @foreach (var car in Model.FeaturedCars)
            {
                var canOrder = OrderWorkflow.CanOrder(car);
                var statusClass = car.Status switch
                {
                    "Đã bán" => "status-badge status-badge--sold",
                    "Khuyến mãi" => "status-badge status-badge--promo",
                    _ => "status-badge status-badge--available"
                };

                <div class="col-md-6 col-xl-4">
                    <article class="car-card h-100">
                        <img src="@car.Image" alt="@car.CarName" class="car-card__image" />
                        <div class="car-card__body">
                            <div class="car-card__meta">
                                <div class="car-card__tag-group">
                                    <span class="pill">@car.BodyType</span>
                                    <span class="pill">@car.Year</span>
                                </div>
                                <span class="@statusClass">@car.Status</span>
                            </div>
                            <p class="car-card__eyebrow">@car.Brand @car.ModelName</p>
                            <h3>@car.CarName</h3>
                            <p class="car-card__subtitle">Màu sắc: @car.Color</p>
                            <div class="car-card__meta">
                                <span class="car-card__price">@car.Price.ToString("N0") VNĐ</span>
                            </div>
                            <div class="car-card__actions">
                                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarID" class="btn btn-accent">Xem xe</a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-controller="Cars" asp-action="Edit" asp-route-id="@car.CarID" class="btn btn-outline-dark">Chỉnh sửa</a>
                                }
                                else if (canOrder)
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="carId" value="@car.CarID" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn btn-outline-dark">Thêm vào giỏ</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state empty-state--dark">
            <h3>Chưa có dữ liệu showroom</h3>
            <p>Đăng nhập để thêm xe.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-accent">Đăng nhập ngay</a>
        </div>
    }
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Điểm mạnh</span>
            <h2>Gọn, rõ, dễ dùng</h2>
        </div>
    </div>

    <div class="service-grid">
        <article class="service-card">
            <span class="service-card__number">01</span>
            <h3>Ảnh lớn</h3>
            <p>Nhìn xe rõ ngay.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">02</span>
            <h3>Lọc nhanh</h3>
            <p>Tìm xe dễ hơn.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">03</span>
            <h3>Đặt xe nhanh</h3>
            <p>Giỏ hàng và checkout mô phỏng.</p>
        </article>
    </div>
</section>
