@model AutoCarShowroom.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
    var heroLine = Model.HeroLine;
}

<section class="hero-showcase">
    <div class="hero-showcase__copy">
        <span class="section-kicker">Showroom theo dòng xe</span>
        <h1>Xem theo dòng xe trước, chọn đúng phiên bản bạn muốn sau.</h1>
        <p class="hero-showcase__description">
            Giao diện mới gom xe theo từng dòng để bạn bấm vào một dòng, chọn phiên bản mong muốn rồi xem thông số, hình toàn cảnh và buồng lái rõ ràng hơn.
        </p>

        <div class="hero-showcase__actions">
            <a asp-controller="Cars" asp-action="Index" class="btn btn-accent btn-lg">Khám phá các dòng xe</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Cars" asp-action="Create" class="btn btn-outline-dark btn-lg">Đăng phiên bản mới</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-dark btn-lg">Đăng nhập quản trị</a>
            }
        </div>

        <div class="hero-showcase__tags">
            <span>@Model.TotalCars phiên bản</span>
            <span>@Model.TotalLines dòng xe</span>
            <span>Hình ảnh và thông số gọn hơn</span>
        </div>
    </div>

    <div class="hero-showcase__visual">
        @if (heroLine != null)
        {
            <article class="feature-card">
                <img src="@heroLine.Image" alt="@heroLine.DisplayName" class="feature-card__image" />
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">@heroLine.Brand · @heroLine.BodyType</span>
                    <h2>@heroLine.DisplayName</h2>
                    <div class="feature-card__meta">
                        <span class="pill">@heroLine.VariantCount phiên bản</span>
                        <span class="pill">@heroLine.NewestYear</span>
                    </div>
                    <p>@heroLine.Highlight</p>
                    <div class="feature-card__footer">
                        <strong>@heroLine.PriceFrom.ToString("N0") - @heroLine.PriceTo.ToString("N0") VNĐ</strong>
                        <a asp-controller="Cars"
                           asp-action="Line"
                           asp-route-brand="@heroLine.Brand"
                           asp-route-modelName="@heroLine.ModelName"
                           asp-route-variantId="@heroLine.RepresentativeCarId"
                           class="btn btn-light">
                            Xem dòng xe
                        </a>
                    </div>
                </div>
            </article>
        }
        else
        {
            <div class="feature-card feature-card--placeholder">
                <div class="feature-card__overlay">
                    <span class="feature-card__badge">AutoCarShowroom</span>
                    <h2>Showroom đã sẵn sàng để trưng bày</h2>
                    <p>Chỉ cần seed dữ liệu hoặc đăng nhập quản trị để thêm các dòng xe đầu tiên.</p>
                </div>
            </div>
        }
    </div>
</section>

<section class="metrics-strip">
    <article class="metric-card">
        <span class="metric-card__label">Tổng phiên bản</span>
        <strong>@Model.TotalCars</strong>
        <p>Đang có trong cơ sở dữ liệu.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Tổng dòng xe</span>
        <strong>@Model.TotalLines</strong>
        <p>Hiển thị theo nhóm, dễ xem hơn.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Đời xe mới nhất</span>
        <strong>@(Model.NewestModelYear == 0 ? "--" : Model.NewestModelYear)</strong>
        <p>Phiên bản mới cập nhật.</p>
    </article>
</section>

@if (ViewData["LoadError"] is string loadError)
{
    <div class="alert alert-warning app-alert" role="alert">
        @loadError
    </div>
}

<section class="section-block section-block--dark">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Nổi bật</span>
            <h2>Các dòng xe đáng xem</h2>
        </div>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-light">Xem toàn bộ danh mục</a>
    </div>

    @if (Model.FeaturedLines.Any())
    {
        <div class="line-grid line-grid--compact">
            @foreach (var line in Model.FeaturedLines)
            {
                <article class="line-card line-card--compact">
                    <div class="line-card__media">
                        <img src="@line.Image" alt="@line.DisplayName" class="line-card__image" />
                    </div>
                    <div class="line-card__body">
                        <div class="line-card__meta">
                            <span class="pill">@line.BodyType</span>
                            <span class="pill">@line.VariantCount phiên bản</span>
                        </div>
                        <p class="car-card__eyebrow">@line.Brand</p>
                        <h3>@line.ModelName</h3>
                        <p class="line-card__highlight">@line.Highlight</p>
                        <strong>@line.PriceFrom.ToString("N0") - @line.PriceTo.ToString("N0") VNĐ</strong>
                        <a asp-controller="Cars"
                           asp-action="Line"
                           asp-route-brand="@line.Brand"
                           asp-route-modelName="@line.ModelName"
                           asp-route-variantId="@line.RepresentativeCarId"
                           class="btn btn-outline-dark">
                            Xem dòng xe
                        </a>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-state empty-state--dark">
            <h3>Chưa có dữ liệu showroom</h3>
            <p>Chạy seed dữ liệu hoặc đăng nhập để bổ sung xe vào hệ thống.</p>
        </div>
    }
</section>

<section class="section-block">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Điểm mạnh</span>
            <h2>Luồng xem xe dễ hơn trước</h2>
        </div>
    </div>

    <div class="service-grid">
        <article class="service-card">
            <span class="service-card__number">01</span>
            <h3>Theo dòng xe</h3>
            <p>Không còn dàn hàng loạt phiên bản trên một trang dài và rối.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">02</span>
            <h3>Theo phiên bản</h3>
            <p>Bấm vào từng bản để xem ngay khác biệt cấu hình, giá bán và nội dung chi tiết.</p>
        </article>
        <article class="service-card">
            <span class="service-card__number">03</span>
            <h3>Theo hình ảnh</h3>
            <p>Có thông số, hình toàn cảnh và buồng lái để phần trình bày đồ án nhìn giống website hãng xe hơn.</p>
        </article>
    </div>
</section>
